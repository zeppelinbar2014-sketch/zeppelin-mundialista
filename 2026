  {q:"¿Qué país fue sede del Mundial 2010?",opts:["Sudáfrica","Nigeria","Egipto","Kenia"],a:0,cat:"HISTORIA",diff:"easy"},
  {q:"¿Dónde se disputó el Mundial 2014?",opts:["Brasil","Argentina","Colombia","Chile"],a:0,cat:"HISTORIA",diff:"easy"},
