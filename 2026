function pickQ(n){ return [...ALL_Q].sort(()=>Math.random()-.5).slice(0,Math.min(n,ALL_Q.length)); }
function genCode(){ return Math.floor(1000+Math.random()*9000).toString(); }
function genId(){ return Math.random().toString(36).substr(2,8); }

const S = {
  code:null, myId:null, myName:null, isHost:false,
  questions:[], currentQ:0, totalQ:10, totalTime:20,
  timeLeft:20, timer:null, answered:false, correctIdx:0, lastQ:-1
};

function showScreen(id){ document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function toast(msg, ms=3000){ const t=document.getElementById('toast'); t.textContent=msg; t.style.display='block'; setTimeout(()=>t.style.display='none',ms); }

document.getElementById('btn-crear').onclick       = () => showScreen('screen-setup');
document.getElementById('btn-unirse').onclick      = () => showScreen('screen-join');
document.getElementById('btn-volver-setup').onclick= () => showScreen('screen-home');
document.getElementById('btn-volver-join').onclick = () => showScreen('screen-home');
document.getElementById('btn-crear-sala').onclick  = createRoom;
document.getElementById('btn-entrar').onclick      = joinRoom;
document.getElementById('start-btn').onclick       = startGame;
document.getElementById('btn-cancelar').onclick    = cancelRoom;
document.getElementById('btn-nueva-partida').onclick = resetGame;

async function createRoom(){
  const name = document.getElementById('host-name').value.trim();
  if(!name){ toast('Ingresá tu nombre'); return; }
  S.myId = genId(); S.myName = name; S.isHost = true;
  S.code = genCode();
  S.totalQ = parseInt(document.getElementById('num-questions').value);
  S.totalTime = parseInt(document.getElementById('time-per-q').value);
  S.questions = pickQ(S.totalQ);
  S.currentQ = 0;
  const room = {
    status:'waiting', totalQ:S.totalQ, timePerQ:S.totalTime,
    questions:S.questions, currentQ:0,
    players:{ [S.myId]:{name, score:0, isHost:true} }
  };
  try {
    await fbSet(`rooms/${S.code}`, room);
    document.getElementById('display-code').textContent = S.code;
    showScreen('screen-waiting');
    startPolling(`rooms/${S.code}`, onRoomUpdate, 1500);
  } catch(e){ toast('Error al crear sala: ' + e.message); }
}

async function joinRoom(){
  const name = document.getElementById('join-name').value.trim();
  const code = document.getElementById('join-code').value.trim();
  if(!name){ toast('Ingresá tu nombre'); return; }
  if(code.length !== 4){ toast('El código tiene 4 dígitos'); return; }
  try {
    const room = await fbGet(`rooms/${code}`);
    if(!room){ toast('Sala no encontrada'); return; }
    if(room.status !== 'waiting'){ toast('El juego ya comenzó'); return; }
    S.myId = genId(); S.myName = name; S.isHost = false; S.code = code;
    S.totalQ = room.totalQ; S.totalTime = room.timePerQ;
    S.questions = room.questions; S.lastQ = -1;
    await fbSet(`rooms/${code}/players/${S.myId}`, {name, score:0, isHost:false});
    document.getElementById('player-wait-name').textContent = name;
    showScreen('screen-waiting-player');
    startPolling(`rooms/${S.code}`, onRoomUpdate, 1500);
  } catch(e){ toast('Error al unirse: ' + e.message); }
}

function onRoomUpdate(room){
  if(!room) return;
  const players = room.players ? Object.entries(room.players).map(([id,p])=>({id,...p})) : [];

  if(document.getElementById('screen-waiting').classList.contains('active')){
    renderWaitingPlayers(players);
    if(players.length >= 2) document.getElementById('start-btn').style.display='block';
  }
  if(document.getElementById('screen-waiting-player').classList.contains('active')){
    renderOtherPlayers(players);
  }

  if(room.status === 'playing'){
    S.questions  = room.questions;
    S.totalQ     = room.totalQ;
    S.totalTime  = room.timePerQ;
    const qIdx   = room.currentQ || 0;
    const onQScreen = document.getElementById('screen-question').classList.contains('active');

    if(!onQScreen){
      S.currentQ = qIdx;
      S.lastQ    = qIdx;
      S.answered = false;
      clearInterval(S.timer);
      showQuestion(players);
    } else if(qIdx !== S.lastQ){
      S.currentQ = qIdx;
      S.lastQ    = qIdx;
      S.answered = false;
      clearInterval(S.timer);
      showQuestion(players);
    } else {
      updateMiniScores(players);
    }
  }

  if(room.status === 'finished'){
    clearInterval(S.timer);
    stopPolling();
    showFinal(players.sort((a,b)=>b.score-a.score));
  }
}

async function startGame(){
  await fbUpdate(`rooms/${S.code}`, {status:'playing', currentQ:0});
}

