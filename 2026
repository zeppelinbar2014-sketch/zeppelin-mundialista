<script>
const FB_URL = "https://zeppelin-trivia-default-rtdb.firebaseio.com";

async function fbGet(path){
  const r = await fetch(`${FB_URL}/${path}.json`);
  return r.json();
}
async function fbSet(path, data){
  await fetch(`${FB_URL}/${path}.json`,{method:'PUT',body:JSON.stringify(data),headers:{'Content-Type':'application/json'}});
}
async function fbUpdate(path, data){
  await fetch(`${FB_URL}/${path}.json`,{method:'PATCH',body:JSON.stringify(data),headers:{'Content-Type':'application/json'}});
}
async function fbDelete(path){
  await fetch(`${FB_URL}/${path}.json`,{method:'DELETE'});
}

let pollTimer = null;
function startPolling(path, cb, interval=1500){
  stopPolling();
  const loop = async () => {
    try { const d = await fbGet(path); cb(d); } catch(e){}
    pollTimer = setTimeout(loop, interval);
  };
  loop();
}
function stopPolling(){
  if(pollTimer){ clearTimeout(pollTimer); pollTimer = null; }
}

// ============================================================
// PREGUNTAS — TEMÁTICA MUNDIALISTA
// ============================================================
const ALL_Q = [
  // ─── HISTORIA Y EDICIONES ───
  {q:"¿En qué año se disputó el primer Mundial de Fútbol?",opts:["1930","1926","1934","1922"],a:0,cat:"HISTORIA",diff:"easy"},
