<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Trivia Mundial · Zeppelin Bar</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@400;600;700&family=Black+Ops+One&display=swap" rel="stylesheet">
<style>
  :root{
    --black:#04080e;
    --dark:#081018;
    --card:#0d1c2e;
    --green:#74ACDF;
    --green-dark:#2e6fa3;
    --gold:#ffffff;
    --gold-dark:#c8ddf0;
    --sky:#74ACDF;
    --fire:#ff4500;
    --white:#f0f8ff;
    --gray:#4a6a8a;
    --correct:#2ecc71;
    --wrong:#e74c3c;
    --arg-celeste:#74ACDF;
    --arg-white:#FFFFFF;
    --arg-sun:#F6B40E;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{
    background:var(--black);
    color:var(--white);
    font-family:'Oswald',sans-serif;
    min-height:100vh;
    overflow-x:hidden;
  }
  /* Campo de fútbol como fondo sutil */
  body::before{
    content:'';
    position:fixed;
    inset:0;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(116,172,223,.09) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 10%, rgba(246,180,14,.04) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 10%, rgba(116,172,223,.05) 0%, transparent 50%);
    pointer-events:none;
    z-index:0;
  }
  /* Líneas de campo como textura */
  body::after{
    content:'';
    position:fixed;
    inset:0;
    background-image:
      linear-gradient(rgba(116,172,223,.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(116,172,223,.02) 1px, transparent 1px);
    background-size:60px 60px;
    pointer-events:none;
    z-index:0;
  }

  .screen{display:none;flex-direction:column;align-items:center;min-height:100vh;padding:20px 16px 60px;position:relative;z-index:1;}
  .screen.active{display:flex;}

  /* ---- HOME ---- */
  .globe{font-size:3.6rem;text-align:center;animation:spin 8s linear infinite;}
  @keyframes spin{from{transform:rotateY(0deg)}to{transform:rotateY(360deg)}}

  .home-title{
    font-family:'Black Ops One',cursive;
    font-size:clamp(2.8rem,10vw,4.2rem);
    color:var(--arg-celeste);
    text-align:center;
    line-height:.95;
    text-shadow:0 0 40px rgba(116,172,223,.5), 3px 3px 0 #000;
    letter-spacing:2px;
    margin-bottom:2px;
  }
  .home-sub{
    font-family:'Bebas Neue',cursive;
    font-size:1rem;
    color:var(--arg-celeste);
    letter-spacing:5px;
    text-align:center;
    margin-bottom:6px;
  }
  .home-brand{
    font-family:'Bebas Neue',cursive;
    font-size:.85rem;
    color:#ff6a00;
    letter-spacing:4px;
    text-align:center;
    margin-bottom:24px;
  }

  .divider{width:80%;height:2px;background:linear-gradient(90deg,transparent,var(--arg-celeste),var(--arg-sun),var(--arg-celeste),transparent);margin:12px 0 24px;}

  .label{font-family:'Bebas Neue',cursive;font-size:1rem;letter-spacing:3px;color:var(--green);margin-bottom:6px;text-align:left;width:100%;max-width:340px;}
  input[type=text],select{width:100%;max-width:340px;background:var(--card);border:1px solid #1e2d1e;border-radius:4px;color:var(--white);font-family:'Oswald',sans-serif;font-size:1.1rem;padding:12px 16px;outline:none;margin-bottom:18px;-webkit-appearance:none;}
  input[type=text]:focus,select:focus{border-color:var(--green);}
  input::placeholder{color:#334;}

  .btn{width:100%;max-width:340px;padding:16px;border:none;border-radius:4px;font-family:'Bebas Neue',cursive;font-size:1.4rem;letter-spacing:3px;cursor:pointer;transition:all .15s;}
  .btn-primary{background:linear-gradient(135deg,var(--green-dark),var(--arg-celeste));color:#fff;box-shadow:0 4px 24px rgba(116,172,223,.35);}
  .btn-primary:active{transform:scale(.97);}
  .btn-gold{background:linear-gradient(135deg,var(--green-dark),var(--arg-celeste));color:#fff;box-shadow:0 4px 24px rgba(116,172,223,.35);margin-top:10px;}
  .btn-outline{background:transparent;border:1px solid #334;color:#668;font-size:1rem;padding:12px;margin-top:8px;}

  .screen-title{font-family:'Black Ops One',cursive;font-size:clamp(1.6rem,6vw,2.4rem);color:var(--gold);text-align:center;letter-spacing:2px;margin-bottom:4px;}
  .screen-sub{font-family:'Bebas Neue',cursive;letter-spacing:4px;color:var(--green);font-size:1rem;text-align:center;margin-bottom:20px;}

  /* Sala de espera */
  .waiting-box{background:var(--card);border:2px solid var(--green-dark);border-radius:8px;padding:22px 20px;width:100%;max-width:340px;text-align:center;margin-bottom:20px;}
  .room-code{font-family:'Black Ops One',cursive;font-size:3.8rem;color:var(--gold);letter-spacing:10px;text-shadow:0 0 20px rgba(255,215,0,.5);}
  .room-label{font-family:'Bebas Neue',cursive;letter-spacing:4px;color:var(--gray);font-size:.85rem;margin-bottom:6px;}
  .players-list{width:100%;max-width:340px;margin-bottom:18px;}
  .players-title{font-family:'Bebas Neue',cursive;letter-spacing:3px;color:var(--gold);font-size:.95rem;margin-bottom:8px;}
  .player-item{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--card);border-radius:4px;margin-bottom:5px;border-left:3px solid var(--green);}
  .player-dot{width:8px;height:8px;background:var(--correct);border-radius:50%;flex-shrink:0;}
  .player-name{font-size:1rem;font-weight:600;}
  .host-badge{margin-left:auto;font-family:'Bebas Neue',cursive;letter-spacing:2px;font-size:.7rem;color:var(--gold);}

  /* Pregunta */
  .q-header{width:100%;display:flex;justify-content:space-between;align-items:center;max-width:420px;margin-bottom:12px;}
  .q-counter{font-family:'Bebas Neue',cursive;letter-spacing:3px;color:var(--gray);font-size:.95rem;}
  .q-timer{font-family:'Black Ops One',cursive;font-size:2.2rem;color:var(--green);min-width:48px;text-align:right;}
  .q-timer.urgent{color:var(--fire);animation:pulse .5s infinite alternate;}
  @keyframes pulse{from{opacity:1}to{opacity:.5}}

  .progress-bar{width:100%;max-width:420px;height:4px;background:#1a2a1a;border-radius:2px;margin-bottom:18px;overflow:hidden;}
  .progress-fill{height:100%;background:linear-gradient(90deg,var(--green-dark),var(--arg-celeste),var(--arg-sun));transition:width 1s linear;}

  .category-tag{
    font-family:'Bebas Neue',cursive;
    letter-spacing:3px;
    font-size:.8rem;
    color:var(--gold);
    margin-bottom:10px;
    text-align:center;
    padding:3px 14px;
    border:1px solid rgba(255,215,0,.2);
    border-radius:20px;
    display:inline-block;
    background:rgba(255,215,0,.05);
  }
  .cat-wrap{text-align:center;margin-bottom:10px;}

  .question-text{
    font-family:'Oswald',sans-serif;
    font-weight:700;
    font-size:clamp(1.05rem,4.2vw,1.35rem);
    color:var(--white);
    text-align:center;
    line-height:1.35;
    max-width:420px;
    margin-bottom:24px;
    min-height:72px;
  }

  .options-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:420px;}
  .option-btn{
    background:var(--card);
    border:2px solid #1a2a1a;
    border-radius:6px;
    color:var(--white);
    font-family:'Oswald',sans-serif;
    font-size:clamp(.82rem,3vw,1rem);
    font-weight:600;
    padding:16px 10px;
    cursor:pointer;
    text-align:center;
    line-height:1.3;
    min-height:72px;
    display:flex;align-items:center;justify-content:center;
    outline:none;
    -webkit-tap-highlight-color:transparent;
    user-select:none;
    transition:border-color .1s, background .1s;
  }
  .option-btn:active{transform:scale(.97);}
  .option-btn.correct{border-color:var(--correct)!important;background:rgba(46,204,113,.15)!important;color:var(--correct)!important;}
  .option-btn.wrong{border-color:var(--wrong)!important;background:rgba(231,76,60,.15)!important;color:var(--wrong)!important;}
  .option-btn.disabled{cursor:default;pointer-events:none;}

  .feedback-msg{margin-top:18px;font-family:'Bebas Neue',cursive;font-size:1.6rem;letter-spacing:4px;text-align:center;min-height:38px;}
  .feedback-msg.correct{color:var(--correct);}
  .feedback-msg.wrong{color:var(--wrong);}
  .points-earned{font-family:'Black Ops One',cursive;font-size:1.8rem;text-align:center;color:var(--gold);margin-top:6px;display:none;}

  .mini-score-wrap{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;max-width:420px;margin-top:14px;}
  .mini-score-chip{background:var(--card);border:1px solid #1e2d1e;border-radius:20px;padding:4px 12px;font-size:.82rem;display:flex;gap:6px;}
  .chip-name{color:#aab;}
  .chip-pts{color:var(--green);font-weight:700;}

  .or-sep{font-family:'Bebas Neue',cursive;letter-spacing:4px;color:var(--gray);font-size:.85rem;text-align:center;margin:4px 0;}
  .waiting-text{font-family:'Bebas Neue',cursive;letter-spacing:3px;color:var(--gray);font-size:.95rem;text-align:center;}
  .dots::after{content:'';animation:dots 1.5s infinite;}
  @keyframes dots{0%{content:''}33%{content:'.'}66%{content:'..'}100%{content:'...'}}

  /* Scoreboard final */
  .scoreboard{width:100%;max-width:420px;margin-bottom:20px;}
  .score-row{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--card);border-radius:6px;margin-bottom:7px;border-left:4px solid var(--gray);position:relative;overflow:hidden;}
  .score-row.rank-1{border-left-color:var(--gold);}
  .score-row.rank-2{border-left-color:#aaa;}
  .score-row.rank-3{border-left-color:#cd7f32;}
  .rank-num{font-family:'Black Ops One',cursive;font-size:1.3rem;color:var(--gray);min-width:28px;}
  .score-row.rank-1 .rank-num{color:var(--gold);}
  .score-row.rank-2 .rank-num{color:#aaa;}
  .score-row.rank-3 .rank-num{color:#cd7f32;}
  .score-name{font-size:1rem;font-weight:600;flex:1;}
  .score-pts{font-family:'Bebas Neue',cursive;font-size:1.3rem;letter-spacing:2px;color:var(--green);}
  .score-bar{position:absolute;bottom:0;left:0;height:2px;background:linear-gradient(90deg,var(--green-dark),var(--arg-celeste));}

  .winner-badge{font-size:3.2rem;text-align:center;margin-bottom:8px;animation:bounce .6s infinite alternate;}
  @keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-8px)}}

  .setup-info{background:var(--card);border:1px solid #1e2d1e;border-radius:6px;padding:14px;width:100%;max-width:340px;margin-bottom:20px;}
  .setup-info p{font-size:.85rem;color:#889;line-height:1.5;text-align:center;}
  .setup-info strong{color:var(--gold);}

  .status-dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--correct);margin-right:6px;animation:pulse .5s infinite alternate;}

  /* Balón decorativo animado */
  .ball-deco{
    font-size:1.8rem;
    display:inline-block;
    animation:roll 3s linear infinite;
  }
  @keyframes roll{
    0%{transform:translateX(-10px) rotate(0deg);opacity:.6;}
    50%{transform:translateX(10px) rotate(180deg);opacity:1;}
    100%{transform:translateX(-10px) rotate(360deg);opacity:.6;}
  }

  .powered{position:fixed;bottom:8px;left:0;right:0;text-align:center;font-family:'Bebas Neue',cursive;letter-spacing:3px;font-size:.65rem;color:#0d1c2e;z-index:1;}
  #toast{position:fixed;bottom:60px;left:50%;transform:translateX(-50%);background:#111820;border:1px solid var(--green);color:var(--white);font-family:'Oswald',sans-serif;padding:10px 20px;border-radius:6px;font-size:.9rem;display:none;z-index:999;white-space:nowrap;}
</style>
</head>
<body>

