};

function showQuestion(players){
  clearInterval(S.timer); S.answered = false;
  const q = S.questions[S.currentQ];
  showScreen('screen-question');
  document.getElementById('q-counter').textContent = `${S.currentQ+1} / ${S.totalQ}`;
  const emoji = CAT_EMOJI[q.cat] || '⚽';
  document.getElementById('q-category').textContent = `${emoji} ${q.cat}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('feedback-msg').textContent = '';
  document.getElementById('feedback-msg').className = 'feedback-msg';
  document.getElementById('points-earned').style.display = 'none';

  const correct = q.opts[q.a];
  const shuffled = [...q.opts].sort(()=>Math.random()-.5);
  S.correctIdx = shuffled.indexOf(correct);
  const labels = ['A','B','C','D'];
  document.getElementById('options-grid').innerHTML = shuffled.map((opt,i)=>`
    <button class="option-btn" id="opt-${i}" onclick="selectAnswer(${i})">
      <span style="color:var(--green);margin-right:4px;">${labels[i]}.</span>${opt}
    </button>`).join('');

  S.timeLeft = S.totalTime;
  document.getElementById('q-timer').textContent = S.timeLeft;
  document.getElementById('q-timer').classList.remove('urgent');
  document.getElementById('progress-fill').style.cssText = 'width:100%;transition:none;';
  setTimeout(()=>{ document.getElementById('progress-fill').style.cssText = `width:0%;transition:width ${S.totalTime}s linear;`; }, 50);
  if(players) updateMiniScores(players);

  S.timer = setInterval(()=>{
    S.timeLeft--;
    document.getElementById('q-timer').textContent = S.timeLeft;
    if(S.timeLeft <= 5) document.getElementById('q-timer').classList.add('urgent');
    if(S.timeLeft <= 0){ clearInterval(S.timer); timeUp(); }
  }, 1000);
}

async function selectAnswer(idx){
  if(S.answered) return;
  S.answered = true; clearInterval(S.timer);
  const q = S.questions[S.currentQ];
  const ok = idx === S.correctIdx;
  const tb = Math.floor(S.timeLeft/S.totalTime*50);
  const pts = ok ? ((q.diff==='easy'?100:q.diff==='medium'?150:200)+tb) : 0;
  showFeedback(idx, ok, pts);
  try {
    const prev = await fbGet(`rooms/${S.code}/players/${S.myId}/score`);
    await fbSet(`rooms/${S.code}/players/${S.myId}/score`, (prev||0) + pts);
  } catch(e){}
  try { await fbSet(`rooms/${S.code}/answers/${S.currentQ}/${S.myId}`, true); } catch(e){}
  if(S.isHost) scheduleNext(3000);
}

function timeUp(){
  if(S.answered) return;
  S.answered = true;
  showFeedback(-1, false, 0);
  if(S.isHost) scheduleNext(2500);
}

function showFeedback(idx, ok, pts){
  document.querySelectorAll('.option-btn').forEach((btn,i)=>{
    btn.classList.add('disabled');
    if(i===S.correctIdx) btn.classList.add('correct');
    else if(i===idx && !ok) btn.classList.add('wrong');
  });
  const fb = document.getElementById('feedback-msg');
  fb.textContent = idx===-1 ? '⏱ ¡TIEMPO!' : ok ? '⚽ ¡CORRECTO!' : '❌ INCORRECTO';
  fb.className = 'feedback-msg ' + (ok?'correct':'wrong');
  if(pts > 0){ const pe=document.getElementById('points-earned'); pe.textContent=`+${pts} pts`; pe.style.display='block'; }
}

async function scheduleNext(delay){
  setTimeout(async()=>{
    const next = S.currentQ + 1;
    try {
      if(next >= S.totalQ){
        await fbUpdate(`rooms/${S.code}`, {status:'finished'});
      } else {
        await fbUpdate(`rooms/${S.code}`, {currentQ: next});
      }
    } catch(e){ toast('Error avanzando pregunta'); }
  }, delay);
}

function renderWaitingPlayers(list){
  document.getElementById('players-list-items').innerHTML = list.map(p=>`
    <div class="player-item"><div class="player-dot"></div><div class="player-name">${p.name}</div>${p.isHost?'<div class="host-badge">ANFITRIÓN</div>':''}</div>`).join('');
  document.getElementById('player-count').textContent = list.length;
  document.getElementById('waiting-msg').textContent = list.length===1 ? 'Esperando más jugadores...' : `${list.length} jugadores listos`;
}
function renderOtherPlayers(list){
  document.getElementById('other-players-list').innerHTML = list.map(p=>`
    <div class="player-item"><div class="player-dot"></div><div class="player-name">${p.name}</div>${p.isHost?'<div class="host-badge">ANFITRIÓN</div>':''}</div>`).join('');
}
function updateMiniScores(list){
  const sorted = [...list].sort((a,b)=>b.score-a.score);
  document.getElementById('mini-scores').innerHTML = sorted.map(p=>
    `<div class="mini-score-chip"><span class="chip-name">${p.name}</span><span class="chip-pts">${p.score}</span></div>`).join('');
}

function showFinal(sorted){
  showScreen('screen-final');
  const mx = sorted[0]?.score || 1;
  document.getElementById('winner-name').textContent = `🏆 ¡CAMPEÓN: ${sorted[0]?.name?.toUpperCase()}!`;
  document.getElementById('final-scoreboard').innerHTML = sorted.map((p,i)=>`
    <div class="score-row rank-${i+1}">
      <div class="rank-num">${i+1}</div>
      <div class="score-name">${p.name}</div>
      <div class="score-pts">${p.score} pts</div>
      <div class="score-bar" style="width:${(p.score/mx)*100}%;"></div>
    </div>`).join('');
}

async function cancelRoom(){
  stopPolling(); clearInterval(S.timer);
  if(S.code) try { await fbDelete(`rooms/${S.code}`); } catch(e){}
  resetGame();
}
function resetGame(){
  stopPolling(); clearInterval(S.timer);
  Object.assign(S,{code:null,myId:null,myName:null,isHost:false,questions:[],currentQ:0,totalQ:10,totalTime:20,timeLeft:20,answered:false,correctIdx:0,lastQ:-1});
  showScreen('screen-home');
}
</script>
</body>
