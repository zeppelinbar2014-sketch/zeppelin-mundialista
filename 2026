  {q:"¿Qué países organizarán conjuntamente el Mundial 2026?",opts:["EEUU, Canadá y México","EEUU, México y Brasil","Canadá, México y Colombia","EEUU, Canadá y Argentina"],a:0,cat:"HISTORIA",diff:"easy"},
  {q:"¿En qué año se disputó el infame 'Maracanazo'?",opts:["1950","1954","1958","1946"],a:0,cat:"HISTORIA",diff:"medium"},
  {q:"¿Qué selección ganó el Mundial de Brasil 1950?",opts:["Uruguay","Brasil","Argentina","España"],a:0,cat:"HISTORIA",diff:"medium"},
  {q:"¿Cuántos goles marcó Uruguay a Brasil en el Maracanazo?",opts:["2","1","3","4"],a:0,cat:"HISTORIA",diff:"medium"},
  {q:"¿Cuántos equipos participan actualmente en la fase de grupos del Mundial?",opts:["32","24","48","36"],a:0,cat:"HISTORIA",diff:"easy"},
  {q:"¿Cuántos equipos tendrá el Mundial 2026?",opts:["48","32","36","40"],a:0,cat:"HISTORIA",diff:"easy"},
  {q:"¿Qué año fue el último Mundial disputado en Europa antes de 2006?",opts:["1998","2002","1994","1990"],a:0,cat:"HISTORIA",diff:"medium"},
